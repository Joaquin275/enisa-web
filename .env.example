# ============================================================
# COPIA ESTE ARCHIVO COMO .env.local PARA DESARROLLO LOCAL
# En Vercel, añade estas variables en Settings → Environment Variables
# ============================================================

# ── BASE DE DATOS (PostgreSQL) ──────────────────────────────
# Obtén esta URL desde Vercel → Storage → Neon Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── AUTENTICACIÓN (NextAuth) ────────────────────────────────
# Genera un secret seguro: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="CAMBIA_ESTO_POR_UN_SECRET_SEGURO"
NEXTAUTH_SECRET="MISMO_VALOR_QUE_AUTH_SECRET"
# En producción pon tu dominio real: https://tudominio.com
NEXTAUTH_URL="https://tudominio.com"

# ── EMAIL (Resend.com — gratis hasta 3000/mes) ──────────────
# Regístrate en resend.com, crea una API key y verifica tu dominio
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_XXXXXXXXXXXXXXXXXX"
EMAIL_FROM="noreply@tudominio.com"
ADMIN_EMAIL="info@tudominio.com"

# ── APP (públicas — accesibles desde el frontend) ──────────
NEXT_PUBLIC_SITE_URL="https://tudominio.com"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_COMPANY_NAME="Enisa Limpieza"
NEXT_PUBLIC_COMPANY_PHONE="+34 691 74 67 30"
NEXT_PUBLIC_COMPANY_EMAIL="info@enisalimpieza.es"

# ── ADMIN DEMO (fallback sin base de datos) ─────────────────
# Cambia estas credenciales por algo seguro en producción
DEMO_ADMIN_EMAIL="admin@enisa.es"
DEMO_ADMIN_PASSWORD="CAMBIA_ESTA_CONTRASENA"

